{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!node_modules",
      "!.next",
      "!dist",
      "!build",
      "!coverage",
      "!.git",
      "!.env*",
      "!*.log",
      "!backup"
    ]
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },

  "javascript": {
    "formatter": {
      "arrowParentheses": "asNeeded",
      "bracketSpacing": true,
      "bracketSameLine": false,
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5"
    },
    "globals": ["window", "document", "fetch", "process", "Buffer", "global"]
  },

  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noConstAssign": "error",
        "noConstantCondition": "error",
        "noEmptyCharacterClassInRegex": "error",
        "noInvalidConstructorSuper": "error",
        "noInvalidUseBeforeDeclaration": "error",
        "noSwitchDeclarations": "error",
        "noUndeclaredVariables": "error",
        "useArrayLiterals": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn",
        "noDangerouslySetInnerHtmlWithChildren": "warn"
      },
      "style": {
        "noImplicitBoolean": "warn",
        "noNonNullAssertion": "warn",
        "useAsConstAssertion": "warn",
        "useConst": "warn"
      },
      "suspicious": {
        "noConsole": "off",
        "noEmptyInterface": "warn",
        "noExplicitAny": "warn",
        "noMisleadingCharacterClass": "error",
        "useGetterReturn": "error"
      },
      "performance": {
        "noBarrelExports": "off"
      }
    }
  },

  "overrides": [
    {
      "includes": ["*.json"],
      "formatter": {
        "indentWidth": 2
      },
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["next.config.mjs", "jest.config.js"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["src/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "correctness": {
            "useValidAriaRole": "warn"
          },
          "suspicious": {
            "noExplicitAny": "error",
            "noImplicitAnyLet": "error"
          },
          "style": {
            "useNamingConvention": "warn"
          }
        }
      }
    }
  ]
}
